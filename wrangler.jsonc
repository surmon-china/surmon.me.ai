{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "surmon-me-ai",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-01",
  "ai": {
    "binding": "AI"
  },
  "r2_buckets": [
    {
      "binding": "RAG_BUCKET",
      "bucket_name": "surmon-me-ai-rag"
    }
  ],
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    },
    "traces": {
      "enabled": false
    }
  }
}